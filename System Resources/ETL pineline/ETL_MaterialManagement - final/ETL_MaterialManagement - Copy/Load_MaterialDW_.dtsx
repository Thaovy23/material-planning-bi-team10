              SQLTask:SqlStatementSource="SELECT MIN(DateValue) AS OverallMinDate&#xA;FROM (&#xA;    SELECT OrderDate AS DateValue FROM Purchasing.PurchaseOrderHeader&#xA;    UNION ALL&#xA;    SELECT ShipDate AS DateValue FROM Purchasing.PurchaseOrderHeader&#xA;    UNION ALL&#xA;    SELECT DueDate AS DateValue FROM Purchasing.PurchaseOrderDetail&#xA;) AllDates&#xA;WHERE DateValue IS NOT NULL;"
