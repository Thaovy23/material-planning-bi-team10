                  description="The SQL command to be executed."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">UPDATE [dbo].[FactMaterial]
   SET [OrderQty] = ?
      ,[ReceivedQty] = ?
      ,[RejectedQty] = ?
      ,[StockedQty] = ?
      ,[UnitPrice] = ?
      ,[LineTotal] = ?
      ,[SubTotal] = ?
      ,[TaxAmt] = ?
      ,[Freight] = ?
      ,[TotalDue] = ?
      ,[ModifiedDate] = ?
 WHERE [ProductKey] = ?
      AND [VendorKey] = ?
      AND [ShipMethodKey] = ?
      AND [OrderDateKey] = ?
      AND [DueDateKey] = ?
      AND [ShipDateKey] = ?</property>
